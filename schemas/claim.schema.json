{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narrativesite.ai/schemas/claim.schema.json",
  "title": "Claim",
  "type": "object",
  "required": ["id", "claim", "type", "source", "status", "visibility", "confidence", "approved_for_public_use"],
  "properties": {
    "id": { "type": "string" },
    "claim": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["metric", "achievement", "role", "credential", "personal_story", "project", "media_detail", "other"]
    },
    "source": {
      "type": "string",
      "enum": ["user_statement", "uploaded_asset", "document", "inferred", "generated_placeholder"]
    },
    "status": {
      "type": "string",
      "enum": ["confirmed", "inferred", "unsupported", "placeholder"]
    },
    "evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "visibility": {
      "type": "string",
      "enum": ["public", "private_context", "ask_before_using", "never_use"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "approved_for_public_use": { "type": "boolean" },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
